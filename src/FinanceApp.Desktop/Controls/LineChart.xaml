<UserControl
    x:Class="FinanceApp.Desktop.Controls.LineChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    SizeChanged="UserControl_SizeChanged">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="LineStrokeBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00FFFF" Offset="0.0" />
            <GradientStop Color="#8A2BE2" Offset="1.0" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="AreaFillBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2500FFFF" Offset="0.0" />
            <GradientStop Color="#00000000" Offset="1.0" />
        </LinearGradientBrush>
    </UserControl.Resources>

    <Grid x:Name="ChartGrid" Height="220" Margin="0,10,0,10">
        <!-- Canvas for drawing shapes -->
        <Canvas x:Name="ChartCanvas" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <!-- Grid Lines and Y-Axis Labels -->
            <Canvas x:Name="GridLinesCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- Area Path -->
            <Path x:Name="AreaPath" Fill="{StaticResource AreaFillBrush}" />

            <!-- Line Path -->
            <Path x:Name="LinePath" Stroke="{StaticResource LineStrokeBrush}" StrokeThickness="3.5" StrokeLineJoin="Round" />

            <!-- Points Markers (only on Hover or simple small circles) -->
            <Canvas x:Name="MarkersCanvas" />
            
            <!-- Tooltip Overlay -->
            <Border x:Name="TooltipBorder" 
                    Background="{StaticResource BgElevatedBrush}" 
                    BorderBrush="{StaticResource BorderSubtleBrush}" 
                    BorderThickness="1" 
                    Padding="10,6" 
                    CornerRadius="6" 
                    Visibility="Collapsed" 
                    Canvas.ZIndex="10">
                <StackPanel>
                    <TextBlock x:Name="TooltipLabel" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock x:Name="TooltipValue" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
