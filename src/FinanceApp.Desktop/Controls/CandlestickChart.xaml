<UserControl
    x:Class="FinanceApp.Desktop.Controls.CandlestickChart"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    SizeChanged="UserControl_SizeChanged">

    <Grid x:Name="ChartGrid" Height="220" Margin="0,10,0,10">
        <Canvas x:Name="ChartCanvas" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Canvas x:Name="GridLinesCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Canvas x:Name="CandlesCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            
            <Border x:Name="TooltipBorder" 
                    Background="#1E1E1E" 
                    BorderBrush="#333333" 
                    BorderThickness="1" 
                    Padding="10,6" 
                    CornerRadius="6" 
                    Visibility="Collapsed" 
                    Canvas.ZIndex="10">
                <StackPanel>
                    <TextBlock x:Name="TooltipDate" FontSize="11" Foreground="#888888" />
                    <TextBlock x:Name="TooltipOHLC" FontSize="12" Foreground="#FFFFFF" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</UserControl>
