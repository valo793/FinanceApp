<UserControl
    x:Class="FinanceApp.Desktop.Controls.AssetBentoCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:inv="using:FinanceApp.Contracts.Investments"
    xmlns:controls="using:FinanceApp.Desktop.Controls"
    HorizontalAlignment="Stretch"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded">

    <Border x:Name="CardBorder"
            CornerRadius="8" 
            Background="{StaticResource BgSurfaceBrush}" 
            BorderThickness="1" 
            BorderBrush="{StaticResource BorderMutedBrush}"
            Padding="14"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            PointerPressed="Card_PointerPressed"
            PointerEntered="Card_PointerEntered"
            PointerExited="Card_PointerExited">

        <Grid RowSpacing="10" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="180" />  <!-- Chart Content: Fixed generous vertical height -->
            </Grid.RowDefinitions>

            <!-- Row 0: Header (Name, Details, Position Value & Actions) -->
            <Grid Grid.Row="0" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />     <!-- Left: Name & Details -->
                    <ColumnDefinition Width="Auto" />  <!-- Right: Position Value & Gain/Loss -->
                    <ColumnDefinition Width="Auto" />  <!-- Far Right: Actions Button -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock x:Name="NameText" 
                               FontWeight="Bold" 
                               FontSize="13" 
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />

                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock x:Name="TickerText" 
                                   FontSize="10" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource AccentCyanBrush}" />

                        <TextBlock x:Name="QuantityText" 
                                   FontSize="10" 
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{StaticResource TextSecondaryBrush}" />

                        <TextBlock x:Name="PriceDetailsText" 
                                   FontSize="10" 
                                   FontFamily="Consolas, Courier New, monospace"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center" Margin="8,0,4,0" HorizontalAlignment="Right">
                    <TextBlock x:Name="PositionValueText" 
                               FontWeight="Bold" 
                               FontSize="13" 
                               FontFamily="Consolas, Courier New, monospace"
                               Foreground="{StaticResource TextPrimaryBrush}" 
                               HorizontalAlignment="Right" />

                    <TextBlock x:Name="GainLossText" 
                               FontSize="10" 
                               FontWeight="SemiBold" 
                               FontFamily="Consolas, Courier New, monospace"
                               HorizontalAlignment="Right" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                    <Button x:Name="PinButton" Background="Transparent" BorderThickness="0" Padding="4" Click="PinButton_Click" ToolTipService.ToolTip="Fixar/Destacar gráfico">
                        <FontIcon x:Name="PinIcon" Glyph="&#xE718;" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>

                    <Button x:Name="ActionsButton" Background="Transparent" BorderThickness="0" Padding="4" ToolTipService.ToolTip="Opções do Ativo">
                        <SymbolIcon Symbol="More" Foreground="{StaticResource TextSecondaryBrush}" />
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Comprar Ativo" Click="Buy_Click">
                                    <MenuFlyoutItem.Icon><SymbolIcon Symbol="Add" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Vender Ativo" Click="Sell_Click">
                                    <MenuFlyoutItem.Icon><SymbolIcon Symbol="Remove" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Registrar Rendimento" Click="Yield_Click">
                                    <MenuFlyoutItem.Icon><SymbolIcon Symbol="Folder" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Editar Cadastro" Click="Edit_Click">
                                    <MenuFlyoutItem.Icon><SymbolIcon Symbol="Edit" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Excluir Ativo" Click="Delete_Click">
                                    <MenuFlyoutItem.Icon><SymbolIcon Symbol="Delete" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Row 1: Chart (Expanded 200px vertical height) -->
            <Grid Grid.Row="1" Height="200" HorizontalAlignment="Stretch">
                <controls:LineChart x:Name="TrendChart" 
                                    Height="200"
                                    VerticalAlignment="Stretch" 
                                    HorizontalAlignment="Stretch"
                                    Visibility="Visible" />

                <controls:CandlestickChart x:Name="CandleChart" 
                                           Height="200"
                                           VerticalAlignment="Stretch" 
                                           HorizontalAlignment="Stretch"
                                           Visibility="Collapsed" />

                <Grid x:Name="LoadingOverlay" Background="{StaticResource BgSurfaceBrush}" Opacity="0.8" Visibility="Collapsed">
                    <ProgressRing IsActive="True" Width="24" Height="24" Foreground="{StaticResource AccentCyanBrush}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
