<Application
    x:Class="FinanceApp.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FinanceApp.Desktop.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
            <converters:AssetTypeConverter x:Key="AssetTypeConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" Inverse="True" />
            <converters:TransactionTypeToColorConverter x:Key="TransactionTypeToColorConverter" />
            <converters:TransactionTypeToIconConverter x:Key="TransactionTypeToIconConverter" />
            <converters:TransactionTypeToPrefixConverter x:Key="TransactionTypeToPrefixConverter" />

            <Color x:Key="BgPrimary">#0B1020</Color>
            <Color x:Key="BgSurface">#12192B</Color>
            <Color x:Key="BgElevated">#18233A</Color>
            <Color x:Key="BorderSubtle">#24314E</Color>
            <Color x:Key="TextPrimary">#F2F5FB</Color>
            <Color x:Key="TextSecondary">#AAB6CF</Color>
            <Color x:Key="AccentCyan">#28D7FF</Color>
            <Color x:Key="AccentViolet">#7C5CFF</Color>
            <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}" />
            <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
            <SolidColorBrush x:Key="AccentCyanBrush" Color="{StaticResource AccentCyan}" />
            <SolidColorBrush x:Key="AccentVioletBrush" Color="{StaticResource AccentViolet}" />
            <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}" />
            <Style x:Key="RecurringFlyoutStyle" TargetType="FlyoutPresenter">
                <Setter Property="Background" Value="{StaticResource BgElevatedBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
