<Page
    x:Class="FinanceApp.Desktop.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:FinanceApp.Desktop.Controls"
    xmlns:converters="using:FinanceApp.Desktop.Converters"
    xmlns:dash="using:FinanceApp.Contracts.Dashboards">

    <Page.Resources>
        <converters:NullableDecimalToVisibilityConverter x:Key="NullableDecimalToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Spacing="20" Padding="24">
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Dashboard"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Command="{x:Bind ViewModel.ToggleValuesVisibilityCommand}"
                        Content="{x:Bind ViewModel.VisibilityIcon, Mode=OneWay}"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="20"
                        Padding="8"
                        VerticalAlignment="Center" />
            </Grid>

            <ProgressBar IsIndeterminate="True"
                          Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="16" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Saldo atual" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentBalanceText, Mode=OneWay}" FontSize="24" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="16" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Saldo projetado" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ProjectedBalanceText, Mode=OneWay}" FontSize="24" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="16" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Receitas do mês" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MonthIncomeText, Mode=OneWay}" FontSize="24" Foreground="{StaticResource AccentCyanBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="16" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Despesas do mês" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MonthExpensesText, Mode=OneWay}" FontSize="24" Foreground="{StaticResource AccentVioletBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 2: Cash Flow and Expense Distribution Charts -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel Spacing="10">
                        <StackPanel>
                            <TextBlock Text="Fluxo de Caixa Histórico" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{x:Bind ViewModel.NetResultText, Mode=OneWay}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <controls:LineChart ItemsSource="{x:Bind ViewModel.CashflowPoints, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Distribuição de Despesas" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" />
                        <controls:DonutChart ItemsSource="{x:Bind ViewModel.ExpenseByCategoryPoints, Mode=OneWay}" />

                        <!-- Category Budget Progress list -->
                        <ListView ItemsSource="{x:Bind ViewModel.Overview.ExpenseByCategory, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  Margin="0,16,0,0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="6" Margin="0,4,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="R$" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" />
                                                <TextBlock Text="{Binding Amount}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                                                <TextBlock Text="/" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Visibility="{Binding BudgetLimit, Converter={StaticResource NullableDecimalToVisibilityConverter}}" VerticalAlignment="Bottom" />
                                                <TextBlock Text="{Binding BudgetLimit}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Visibility="{Binding BudgetLimit, Converter={StaticResource NullableDecimalToVisibilityConverter}}" VerticalAlignment="Bottom" />
                                            </StackPanel>
                                        </Grid>
                                        <ProgressBar Value="{Binding BudgetPercentage}"
                                                     Maximum="100"
                                                     Height="4"
                                                     CornerRadius="2"
                                                     Foreground="{StaticResource AccentVioletBrush}"
                                                     Visibility="{Binding BudgetLimit, Converter={StaticResource NullableDecimalToVisibilityConverter}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 3: Net Worth Projection and Recurrences -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Projeção de Patrimônio Líquido (30 dias)" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" />
                        <controls:LineChart ItemsSource="{x:Bind ViewModel.NetWorthPoints, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel Spacing="16" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Recorrências Pendentes" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Próximos compromissos agendados" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <Border Padding="16" CornerRadius="12" Background="{StaticResource BgElevatedBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.PendingRecurrencesText, Mode=OneWay}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource AccentCyanBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="transações a materializar" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="{StaticResource AccentVioletBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
