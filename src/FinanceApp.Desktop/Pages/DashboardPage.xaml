<Page
    x:Class="FinanceApp.Desktop.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Spacing="20" Padding="24">
            <TextBlock Text="Dashboard"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" />

            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="16" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Saldo atual" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentBalanceText, Mode=OneWay}" FontSize="24" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="16" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Saldo projetado" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ProjectedBalanceText, Mode=OneWay}" FontSize="24" Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="16" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Receitas do mês" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MonthIncomeText, Mode=OneWay}" FontSize="24" Foreground="{StaticResource AccentCyanBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Padding="16" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Despesas do mês" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.MonthExpensesText, Mode=OneWay}" FontSize="24" Foreground="{StaticResource AccentVioletBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Fluxo de caixa" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.NetResultText, Mode=OneWay}" FontSize="16" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Recorrências pendentes" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.PendingRecurrencesText, Mode=OneWay}" FontSize="16" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="{StaticResource AccentVioletBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
