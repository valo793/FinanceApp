<Page
    x:Class="FinanceApp.Desktop.Pages.TransactionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FinanceApp.Desktop.Converters">

    <Page.Resources>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter" />
        <converters:TransactionTypeToColorConverter x:Key="TransactionTypeToColorConverter" />
        <converters:TransactionTypeToIconConverter x:Key="TransactionTypeToIconConverter" />
        <converters:TransactionTypeToPrefixConverter x:Key="TransactionTypeToPrefixConverter" />
    </Page.Resources>

    <Grid Padding="24" Background="{StaticResource BgPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="Transações e Categorias"
                           FontSize="28" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Gerencie seus lançamentos e fontes em um único painel integrado"
                           FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Background="{StaticResource AccentCyanBrush}"
                        Foreground="Black"
                        Padding="16,8"
                        CornerRadius="8"
                        FontWeight="SemiBold"
                        Click="AddIncome_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE109;" Foreground="Black" />
                        <TextBlock Text="Nova Receita" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Background="{StaticResource AccentVioletBrush}"
                        Foreground="White"
                        Padding="16,8"
                        CornerRadius="8"
                        FontWeight="SemiBold"
                        Click="AddExpense_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE108;" Foreground="White" />
                        <TextBlock Text="Novo Gasto" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content Grid (Split screen) -->
        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Column 0: Unified Transactions List -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Filter Row -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="TypeFilterComboBox" 
                              SelectionChanged="TypeFilterComboBox_SelectionChanged" 
                              SelectedIndex="0" Width="200" CornerRadius="6"
                              Background="{StaticResource BgSurfaceBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}">
                        <ComboBoxItem Content="Todos os Lançamentos" />
                        <ComboBoxItem Content="Receitas" />
                        <ComboBoxItem Content="Despesas" />
                    </ComboBox>
                </Grid>

                <ProgressBar Grid.Row="1" IsIndeterminate="True"
                             Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                             Margin="0,0,0,8" />

                <!-- Transactions ListView -->
                <ListView Grid.Row="2"
                          ItemsSource="{x:Bind ViewModel.FilteredTransactions, Mode=OneWay}"
                          Background="Transparent"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" Background="{StaticResource BgSurfaceBrush}" CornerRadius="8" Margin="0,4,0,4">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Col 0: Type Icon Circle -->
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" 
                                            Background="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}, ConverterParameter='background'}" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="{Binding TransactionType, Converter={StaticResource TransactionTypeToIconConverter}}" 
                                                  FontSize="14" 
                                                  Foreground="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}" />
                                    </Border>

                                    <!-- Col 1: Details -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Description}" FontSize="15" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding CompetenceDate}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="•" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding AccountName}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="•" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding CategoryName}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Col 2: Amount -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TransactionType, Converter={StaticResource TransactionTypeToPrefixConverter}}" 
                                                       FontSize="15" FontWeight="SemiBold" 
                                                       Foreground="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}" />
                                            <TextBlock Text="{Binding AmountExpected}" 
                                                       FontSize="15" FontWeight="SemiBold" 
                                                       Foreground="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Col 3: Status Badge -->
                                    <Border Grid.Column="3" Padding="8,4" CornerRadius="6" Background="{StaticResource BgElevatedBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </Border>

                                    <!-- Col 4: Action Buttons -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button Background="Transparent" BorderThickness="0" Padding="4" Click="DeleteTransaction_Click" Tag="{Binding Id}">
                                            <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#FF453A" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
                <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="{StaticResource AccentVioletBrush}"
                           VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="12" />
            </Grid>

            <!-- Column 1: Categories Sidebar Panel -->
            <Border Grid.Column="1" Background="{StaticResource BgSurfaceBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="{StaticResource BorderSubtleBrush}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Section 0: Expense Categories -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Categorias de Despesa" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Nova" 
                                    Background="{StaticResource AccentVioletBrush}" Foreground="White" 
                                    CornerRadius="6" Padding="8,4" Click="NewExpenseCategory_Click" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ExpenseCategories, Mode=OneWay}" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" Background="{StaticResource BgElevatedBrush}" CornerRadius="6" Margin="0,3,0,3">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5" Background="{Binding Color, Converter={StaticResource HexToBrushConverter}, ConverterParameter='AccentVioletBrush'}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Icon}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                            <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Center" Click="DeleteExpenseCategory_Click" Tag="{Binding Id}">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#FF453A" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- Section 1: Income Categories -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Fontes de Receita" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Nova" 
                                    Background="{StaticResource AccentCyanBrush}" Foreground="Black" 
                                    CornerRadius="6" Padding="8,4" Click="NewIncomeCategory_Click" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.IncomeCategories, Mode=OneWay}" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8" Background="{StaticResource BgElevatedBrush}" CornerRadius="6" Margin="0,3,0,3">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5" Background="{Binding Color, Converter={StaticResource HexToBrushConverter}, ConverterParameter='AccentCyanBrush'}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Icon}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                                            <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Padding="4" VerticalAlignment="Center" Click="DeleteIncomeCategory_Click" Tag="{Binding Id}">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#FF453A" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
