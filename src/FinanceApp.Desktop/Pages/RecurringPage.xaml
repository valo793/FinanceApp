<Page
    x:Class="FinanceApp.Desktop.Pages.RecurringPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FinanceApp.Desktop.Converters"
    xmlns:viewmodels="using:FinanceApp.Desktop.ViewModels">

    <Page.Resources>
        <Flyout x:Key="OccurrenceDetailsFlyout" Placement="Bottom" FlyoutPresenterStyle="{StaticResource RecurringFlyoutStyle}">
            <StackPanel Width="220" Spacing="8">
                <TextBlock x:Name="FlyoutDescription" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                <TextBlock x:Name="FlyoutFrequency" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock x:Name="FlyoutAmount" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                
                <Button x:Name="FlyoutPauseButton"
                        Content="Pausar Recorrência" 
                        Click="PauseRecurring_Click" 
                        HorizontalAlignment="Stretch" 
                        Background="Transparent" 
                        Foreground="#FF453A" 
                        BorderThickness="1" 
                        BorderBrush="#FF453A"
                        CornerRadius="6"
                        Margin="0,6,0,0" />
            </StackPanel>
        </Flyout>
    </Page.Resources>

    <Grid Padding="24" Background="{StaticResource BgPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header and Month Navigation -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="Agenda e Planejamento"
                        FontSize="28" FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" />
                        
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="◀" 
                        Command="{x:Bind ViewModel.PreviousMonthCommand}"
                        Background="{StaticResource BgElevatedBrush}" 
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Padding="12,8"
                        CornerRadius="6" />
                <Button Content="Hoje" 
                        Command="{x:Bind ViewModel.TodayCommand}"
                        Background="{StaticResource BgElevatedBrush}" 
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Padding="16,8"
                        CornerRadius="6" />
                <Button Content="▶" 
                        Command="{x:Bind ViewModel.NextMonthCommand}"
                        Background="{StaticResource BgElevatedBrush}" 
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Padding="12,8"
                        CornerRadius="6" />
                
                <Border Background="{StaticResource BgSurfaceBrush}" Padding="16,8" CornerRadius="6" Margin="8,0,0,0" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                    <TextBlock Text="{x:Bind ViewModel.CurrentMonthYearText, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource AccentCyanBrush}" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Loader -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True"
                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                      Margin="0,0,0,16" />

        <!-- Days of Week Header -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="DOMINGO" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Grid.Column="1" Text="SEGUNDA" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Grid.Column="2" Text="TERÇA" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Grid.Column="3" Text="QUARTA" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Grid.Column="4" Text="QUINTA" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Grid.Column="5" Text="SEXTA" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBlock Grid.Column="6" Text="SÁBADO" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" />
        </Grid>

        <!-- Custom Month Calendar Grid -->
        <GridView Grid.Row="3"
                  ItemsSource="{x:Bind ViewModel.CalendarDays, Mode=OneWay}"
                  SelectionMode="None"
                  Background="Transparent"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Stretch">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="7" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="2" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:CalendarDayCell">
                    <Border CornerRadius="8" 
                            Background="{Binding CellBackgroundBrush}" 
                            BorderBrush="{Binding CellBorderBrush}" 
                            BorderThickness="{Binding CellBorderThickness}" 
                            Width="135" 
                            Height="105" 
                            Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Day Number -->
                            <TextBlock Grid.Row="0" 
                                       Text="{Binding DayNumber}" 
                                       FontWeight="SemiBold" 
                                       FontSize="13" 
                                       Foreground="{Binding CellForegroundBrush}" 
                                       HorizontalAlignment="Right" />

                            <!-- List of Occurrences inside the day cell populated dynamically -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,4,0,0">
                                <StackPanel x:Name="OccurrencesPanel" 
                                            Loaded="OccurrencesPanel_Loaded" 
                                            DataContextChanged="OccurrencesPanel_DataContextChanged" 
                                            Spacing="4" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <TextBlock Grid.Row="3" Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   Foreground="{StaticResource AccentVioletBrush}"
                   VerticalAlignment="Bottom" />
    </Grid>
</Page>
