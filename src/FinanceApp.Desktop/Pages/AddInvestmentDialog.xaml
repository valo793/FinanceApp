<ContentDialog
    x:Class="FinanceApp.Desktop.Pages.AddInvestmentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Novo Investimento"
    PrimaryButtonText="Salvar"
    CloseButtonText="Cancelar"
    DefaultButton="Primary"
    RequestedTheme="Dark">

    <StackPanel Spacing="16" Width="360">
        <StackPanel x:Name="TickerPanel" Spacing="8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TickerInput" Grid.Column="0" Header="Ticker (opcional)" PlaceholderText="Ex: PETR4.SA" LostFocus="TickerInput_LostFocus"
                         ToolTipService.ToolTip="Ticker do ativo (ex: PETR4.SA, MXRF11.SA). Se preenchido, os dados de preço e nome serão atualizados automaticamente via Yahoo Finance." />
                <Button x:Name="ValidateTickerButton" Grid.Column="1" Content="Validar" VerticalAlignment="Bottom" Click="ValidateTickerButton_Click"
                        ToolTipService.ToolTip="Valida o ticker digitado na API do Yahoo Finance e autocompleta as informações do ativo." />
            </Grid>
            
            <ProgressRing x:Name="ValidationProgress" IsActive="False" HorizontalAlignment="Left" Width="20" Height="20" Visibility="Collapsed" />
            <TextBlock x:Name="ValidationStatusText" FontSize="12" Foreground="Red" Visibility="Collapsed" />
        </StackPanel>

        <TextBox x:Name="NameInput" Header="Nome do Ativo *" PlaceholderText="Ex: Ações Petrobras, CDB Banco Inter"
                 ToolTipService.ToolTip="Nome amigável de exibição do ativo na sua carteira de investimentos." />

        <ComboBox x:Name="AssetTypeInput" Header="Tipo de Ativo *" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="AssetTypeInput_SelectionChanged"
                  ToolTipService.ToolTip="Classificação do ativo para divisão e agrupamento no gráfico de alocação de carteira.">
            <ComboBoxItem Tag="stock">Ações</ComboBoxItem>
            <ComboBoxItem Tag="fii">FIIs</ComboBoxItem>
            <ComboBoxItem Tag="cdb">CDB</ComboBoxItem>
            <ComboBoxItem Tag="tesouro">Tesouro Direto</ComboBoxItem>
            <ComboBoxItem Tag="crypto">Cripto</ComboBoxItem>
            <ComboBoxItem Tag="fund">Outros Fundos</ComboBoxItem>
        </ComboBox>

        <!-- Fixed Income Indexers Panel -->
        <StackPanel x:Name="IndexerPanel" Spacing="12" Visibility="Collapsed">
            <ComboBox x:Name="IndexerTypeInput" Header="Indexador (opcional)" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="IndexerTypeInput_SelectionChanged"
                      ToolTipService.ToolTip="O indexador de rentabilidade contratado para fins de projeção de saldo.">
                <ComboBoxItem Tag="cdi">CDI</ComboBoxItem>
                <ComboBoxItem Tag="ipca">IPCA+</ComboBoxItem>
                <ComboBoxItem Tag="pre">Pré-fixado</ComboBoxItem>
            </ComboBox>

            <NumberBox x:Name="IndexerRateInput" Header="Taxa / Percentual (%)" Value="100" SmallChange="1" LargeChange="10"
                       ToolTipService.ToolTip="Percentual do indexador (ex: 120% do CDI) ou taxa anual pré-fixada (ex: 12.5%)." />
            
            <NumberBox x:Name="IndexerAdditionalRateInput" Header="Taxa Adicional (% a.a.)" Value="0.00" SmallChange="0.1" LargeChange="1.0" Visibility="Collapsed"
                       ToolTipService.ToolTip="Taxa fixa adicional somada à variação da inflação (ex: IPCA + 6.5%)." />
        </StackPanel>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <NumberBox x:Name="QuantityInput" Grid.Column="0" Header="Quantidade *" Value="1" SmallChange="1" LargeChange="10"
                       ToolTipService.ToolTip="Quantidade total de cotas ou títulos que você possui deste ativo." />
            <NumberBox x:Name="AveragePriceInput" Grid.Column="1" Header="Preço Pago (R$) *" Value="0.00" SmallChange="0.1" LargeChange="1.0"
                       ToolTipService.ToolTip="Preço médio unitário pago na aquisição das cotas." />
        </Grid>

        <NumberBox x:Name="CurrentPriceInput" Header="Preço Atual (R$) *" Value="0.00" SmallChange="0.1" LargeChange="1.0"
                   ToolTipService.ToolTip="Cotação atual do ativo. Para ativos com ticker, este valor é atualizado automaticamente a cada 4 horas." />

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="AccountInput" Grid.Column="0" Header="Conta *" HorizontalAlignment="Stretch"
                      DisplayMemberPath="Name" SelectedValuePath="Id"
                      ToolTipService.ToolTip="A conta vinculada a este investimento." />
            
            <CalendarDatePicker x:Name="PurchaseDateInput" Grid.Column="1" Header="Data de Compra" HorizontalAlignment="Stretch"
                                PlaceholderText="Selecione"
                                ToolTipService.ToolTip="A data em que o investimento foi realizado." />
        </Grid>

        <CheckBox x:Name="IsWatchlistInput" Content="Adicionar à Watchlist (Acompanhamento)" Margin="0,4,0,4"
                  ToolTipService.ToolTip="Se marcado, este ativo servirá apenas para monitoramento e não fará parte dos cálculos gerais de saldo e rentabilidade de sua carteira." />

        <ComboBox x:Name="RiskLevelInput" Header="Nível de Risco *" HorizontalAlignment="Stretch" SelectedIndex="1"
                  ToolTipService.ToolTip="Selecione o nível de risco associado para análise de perfil de carteira.">
            <ComboBoxItem Tag="low">Baixo</ComboBoxItem>
            <ComboBoxItem Tag="moderate">Moderado</ComboBoxItem>
            <ComboBoxItem Tag="high">Alto</ComboBoxItem>
        </ComboBox>
    </StackPanel>
</ContentDialog>
