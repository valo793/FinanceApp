<Page
    x:Class="FinanceApp.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24" Background="{StaticResource BgPrimaryBrush}">
        <StackPanel Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">
            <SymbolIcon Symbol="Setting" Margin="0,0,0,10" Foreground="{StaticResource AccentVioletBrush}">
                <SymbolIcon.RenderTransform>
                    <ScaleTransform ScaleX="3" ScaleY="3" CenterX="10" CenterY="10" />
                </SymbolIcon.RenderTransform>
            </SymbolIcon>
            <TextBlock Text="Configurações" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="Preferências de segurança, MFA e temas estarão disponíveis na Sprint 3." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
