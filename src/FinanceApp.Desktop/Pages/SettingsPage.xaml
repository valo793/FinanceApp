<Page
    x:Class="FinanceApp.Desktop.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Background="{StaticResource BgPrimaryBrush}">
        <StackPanel Spacing="24" Padding="24" MaxWidth="600" HorizontalAlignment="Left">
            
            <!-- Header Section -->
            <StackPanel>
                <TextBlock Text="Configurações"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Personalize sua experiência no FinanceApp"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Loading Indicator -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Background="Transparent"
                         Foreground="{StaticResource AccentVioletBrush}" />

            <!-- Theme Settings -->
            <Border Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Aparência" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Tema Visual" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Escolha entre o tema escuro e o tema claro (futuro)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ComboBox x:Name="ThemeInput" Grid.Column="1" Width="150" SelectedIndex="0">
                            <ComboBoxItem Tag="dark">Escuro (Padrão)</ComboBoxItem>
                            <ComboBoxItem Tag="light" IsEnabled="False">Claro</ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <MenuFlyoutSeparator />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Modo de Exibição da Janela" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Escolha como o aplicativo deve abrir por padrão" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ComboBox x:Name="WindowModeInput" Grid.Column="1" Width="170" SelectedIndex="0">
                            <ComboBoxItem Tag="windowed">Modo Janela</ComboBoxItem>
                            <ComboBoxItem Tag="maximized">Maximizado</ComboBoxItem>
                            <ComboBoxItem Tag="fullscreen">Tela Cheia (Full Screen)</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Dashboard preferences -->
            <Border Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Dashboard e Privacidade" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Exibir saldos ao abrir" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Mostra os valores por padrão logo ao abrir o aplicativo" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" IsOn="{x:Bind ViewModel.ShowValuesOnStart, Mode=TwoWay}" OnContent="" OffContent="" />
                    </Grid>

                    <MenuFlyoutSeparator />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Período Padrão" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Período selecionado por padrão para carregar gráficos e KPIs" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                        </StackPanel>
                        <ComboBox x:Name="PeriodInput" Grid.Column="1" Width="150" SelectedIndex="0">
                            <ComboBoxItem Tag="current_month">Mês Atual</ComboBoxItem>
                            <ComboBoxItem Tag="last_3_months">Últimos 3 Meses</ComboBoxItem>
                            <ComboBoxItem Tag="last_6_months">Últimos 6 Meses</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Security Settings (MFA) -->
            <Border Padding="20" CornerRadius="16" Background="{StaticResource BgSurfaceBrush}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Segurança de Acesso" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Autenticação de Dois Fatores (MFA / 2FA)" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Adiciona uma camada extra de segurança usando um aplicativo autenticador (Google Authenticator, Microsoft Authenticator, etc.)" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        
                        <Button Grid.Column="1" 
                                x:Name="MfaToggleButton"
                                Click="MfaToggle_Click"
                                Content="{x:Bind ViewModel.MfaButtonText, Mode=OneWay}"
                                Background="{StaticResource AccentVioletBrush}"
                                Foreground="White"
                                Padding="16,8"
                                CornerRadius="6"
                                FontWeight="SemiBold"
                                VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save button -->
            <Button Click="SaveSettings_Click"
                    Background="{StaticResource AccentVioletBrush}"
                    Foreground="White"
                    Padding="24,12"
                    CornerRadius="8"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Save" />
                    <TextBlock Text="Salvar Alterações" />
                </StackPanel>
            </Button>

            <!-- Error banner -->
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="{StaticResource AccentVioletBrush}"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </ScrollViewer>
</Page>
