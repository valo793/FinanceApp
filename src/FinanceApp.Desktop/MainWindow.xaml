<Window
    x:Class="FinanceApp.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FinanceApp">
    <Grid Background="{StaticResource BgPrimaryBrush}">
        <NavigationView x:Name="NavView"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsPaneOpen="True"
                        IsSettingsVisible="False"
                        Background="{StaticResource BgSurfaceBrush}"
                        SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="dashboard">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Home" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Gastos" Tag="expenses">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Remove" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Receitas" Tag="incomes">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Add" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Contas" Tag="accounts">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Contact" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Categorias" Tag="categories">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Folder" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Recorrências" Tag="recurring">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Refresh" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Investimentos" Tag="investments">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Globe" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Configurações" Tag="settings">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Setting" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Sair" Tag="logout">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Import" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="RootFrame" />
        </NavigationView>
    </Grid>
</Window>
