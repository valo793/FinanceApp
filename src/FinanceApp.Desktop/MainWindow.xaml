<Window
    x:Class="FinanceApp.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FinanceApp">
    <Grid Background="{StaticResource BgPrimaryBrush}">
        <Grid.KeyboardAccelerators>
            <!-- Navigation Shortcuts -->
            <KeyboardAccelerator Key="D" Modifiers="Control" Invoked="NavAccelerator_Invoked" />
            <KeyboardAccelerator Key="T" Modifiers="Control" Invoked="NavAccelerator_Invoked" />
            <KeyboardAccelerator Key="A" Modifiers="Control" Invoked="NavAccelerator_Invoked" />
            <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="NavAccelerator_Invoked" />
            <KeyboardAccelerator Key="I" Modifiers="Control" Invoked="NavAccelerator_Invoked" />
            <KeyboardAccelerator Key="S" Modifiers="Control" Invoked="NavAccelerator_Invoked" />
            <KeyboardAccelerator Key="Q" Modifiers="Control" Invoked="LogoutAccelerator_Invoked" />

            <!-- Global Actions -->
            <KeyboardAccelerator Key="F11" Invoked="FullScreenAccelerator_Invoked" />
            <KeyboardAccelerator Key="B" Modifiers="Control" Invoked="TogglePaneAccelerator_Invoked" />
            <KeyboardAccelerator Key="P" Modifiers="Control" Invoked="OpenCommandPaletteAccelerator_Invoked" />
            <KeyboardAccelerator Key="H" Modifiers="Control" Invoked="ToggleValuesAccelerator_Invoked" />
        </Grid.KeyboardAccelerators>
        <NavigationView x:Name="NavView"
                        PaneDisplayMode="Left"
                        IsBackButtonVisible="Collapsed"
                        IsPaneOpen="True"
                        IsSettingsVisible="False"
                        Background="{StaticResource BgSurfaceBrush}"
                        SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="dashboard">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Home" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Transações" Tag="transactions">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="List" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Contas" Tag="accounts">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Contact" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Recorrências" Tag="recurring">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Refresh" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Investimentos" Tag="investments">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Globe" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Configurações" Tag="settings">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Setting" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Sair" Tag="logout">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Import" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="RootFrame" />
        </NavigationView>

        <InfoBar x:Name="GlobalInfoBar"
                 IsOpen="False"
                 Severity="Informational"
                 IsIconVisible="True"
                 Message=""
                 Margin="24"
                 VerticalAlignment="Top"
                 HorizontalAlignment="Right" />
    </Grid>
</Window>
